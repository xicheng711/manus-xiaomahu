modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Go (手机预览)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_PORT=5000 pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Expo Go (手机预览)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Use shell instead'"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 5002
externalPort = 6000

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 5173

[[ports]]
localPort = 23636
externalPort = 5000

[[ports]]
localPort = 23637
externalPort = 4200

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "node dist/index.js"]
build = ["bash", "-c", "pnpm build && npx expo export --platform web --output-dir dist/public"]

[userenv]

[userenv.shared]
EXPO_PUBLIC_API_BASE_URL = "https://bb61136f-b877-4468-976e-ad1f0dd820c5-00-13353agfbwm1u.worf.replit.dev"
